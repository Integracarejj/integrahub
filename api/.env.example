PORT=4000

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SQL_SERVER=
AZURE_SQL_DATABASE=

# Optional: separate Graph credentials (falls back to AZURE_* vars if not set)
# GRAPH_TENANT_ID=
# GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET=

# Optional: SharePoint discovery for recap portal diagnostics
# RECAP_SHAREPOINT_HOSTNAME=integracare.sharepoint.com
# RECAP_SHAREPOINT_SITE_PATH=/sites/RecapitalizationHub

# Optional: allow write test in graph diagnostics (default false)
# GRAPH_DIAGNOSTICS_ALLOW_WRITE=true
